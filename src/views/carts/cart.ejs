<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Reparatech - Mi Carrito' , cssFile: 'home.css' }) %>

    <body>
        <%- include('../partials/header') %>

            <main>
                <div style="max-width: 1200px; margin: 40px auto; padding: 0 20px;">
                    <div style="text-align: center; margin-bottom: 40px;">
                        <h1 style="color: var(--text-main); font-size: 32px; font-weight: 700;">🛍️ Tu Carrito de
                            Compras</h1>
                        <p style="color: var(--text-light); margin-top: 10px;">Revisa tus productos y finaliza tu pedido
                            de forma segura.</p>
                    </div>

                    <% if (locals.cartProducts && locals.cartProducts.length> 0) { %>
                        <div style="display: flex; gap: 30px; flex-wrap: wrap; align-items: flex-start;">

                            <!-- Lista de Productos (Izquierda) -->
                            <div style="flex: 2; min-width: 320px; display: flex; flex-direction: column; gap: 20px;">
                                <% locals.cartProducts.forEach(item=> { %>
                                    <div
                                        style="display: flex; background: var(--surface-main); border: 1px solid var(--border-light); border-radius: 12px; padding: 20px; box-shadow: var(--shadow-sm); align-items: center; gap: 20px; transition: transform 0.2s;">

                                        <!-- Imagen -->
                                        <div
                                            style="width: 100px; height: 100px; background: var(--bg-body); border-radius: 8px; display: flex; justify-content: center; align-items: center; overflow: hidden; flex-shrink: 0;">
                                            <img src="/images/products/<%= item.product.image %>"
                                                alt="<%= item.product.name %>"
                                                style="max-width: 100%; max-height: 100%; object-fit: contain;">
                                        </div>

                                        <!-- Info -->
                                        <div style="flex: 1;">
                                            <h3
                                                style="color: var(--text-main); font-size: 18px; font-weight: 600; margin-bottom: 8px;">
                                                <%= item.product.name %>
                                            </h3>
                                            <span
                                                style="color: var(--primary-color); font-weight: 800; font-size: 20px;">$
                                                <%= Number(item.unit_price).toFixed(2) %></span>
                                            <span
                                                style="color: var(--text-light); font-size: 13px; display: block; margin-top: 5px;">Precio
                                                Unitario</span>
                                        </div>

                                        <!-- Controles -->
                                        <div
                                            style="display: flex; flex-direction: column; align-items: center; gap: 15px;">

                                            <!-- Cantidad -->
                                            <div
                                                style="display: flex; align-items: center; background: var(--bg-body); border: 1px solid var(--border-light); border-radius: 6px; overflow: hidden;">
                                                <form action="/cart/edit/<%= item.id %>?_method=PUT" method="POST"
                                                    style="margin: 0;">
                                                    <input type="hidden" name="action" value="decrease">
                                                    <button type="submit"
                                                        style="background: none; border: none; padding: 8px 12px; color: var(--text-main); cursor: pointer; transition: background 0.2s;"
                                                        <%=item.quantity <=1 ? 'disabled' : '' %>
                                                        onmouseover="this.style.background='var(--primary-color)';
                                                        this.style.color='#fff';"
                                                        onmouseout="this.style.background='none';
                                                        this.style.color='var(--text-main)';">-</button>
                                                </form>

                                                <span
                                                    style="padding: 0 15px; font-weight: 600; color: var(--text-main);">
                                                    <%= item.quantity %>
                                                </span>

                                                <form action="/cart/edit/<%= item.id %>?_method=PUT" method="POST"
                                                    style="margin: 0;">
                                                    <input type="hidden" name="action" value="increase">
                                                    <button type="submit"
                                                        style="background: none; border: none; padding: 8px 12px; color: var(--text-main); cursor: pointer; transition: background 0.2s;"
                                                        onmouseover="this.style.background='var(--primary-color)'; this.style.color='#fff';"
                                                        onmouseout="this.style.background='none'; this.style.color='var(--text-main)';">+</button>
                                                </form>
                                            </div>

                                            <!-- Eliminar -->
                                            <form action="/cart/remove/<%= item.id %>?_method=DELETE" method="POST"
                                                style="margin: 0;">
                                                <button type="submit"
                                                    style="background: none; border: none; color: #ef4444; font-size: 14px; cursor: pointer; display: flex; align-items: center; gap: 5px; font-weight: 600; text-decoration: underline;">
                                                    <i class="fa-solid fa-trash-can"></i> Quitar
                                                </button>
                                            </form>

                                        </div>
                                    </div>
                                    <% }) %>
                            </div>

                            <!-- Panel de Resumen (Derecha) -->
                            <div
                                style="flex: 1; min-width: 300px; background: var(--surface-main); border: 1px solid var(--border-color); border-radius: 12px; padding: 30px; box-shadow: var(--shadow-sm); position: sticky; top: 20px;">
                                <h2
                                    style="color: var(--text-main); font-size: 22px; margin-bottom: 25px; border-bottom: 1px solid var(--border-light); padding-bottom: 15px;">
                                    Resumen de Compra</h2>

                                <div
                                    style="display: flex; justify-content: space-between; margin-bottom: 15px; color: var(--text-light); font-size: 16px;">
                                    <span>Subtotal Productos</span>
                                    <span style="font-weight: 600;">$<%= Number(locals.total).toFixed(2) %></span>
                                </div>
                                <div
                                    style="display: flex; justify-content: space-between; margin-bottom: 25px; color: #10b981; font-size: 16px;">
                                    <span>Descuentos (Promo)</span>
                                    <span style="font-weight: 600;">-$0.00</span>
                                </div>

                                <div
                                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; padding-top: 20px; border-top: 1px solid var(--border-light);">
                                    <span style="color: var(--text-main); font-size: 18px; font-weight: 600;">Total a
                                        Pagar</span>
                                    <span style="color: var(--primary-color); font-size: 28px; font-weight: 800;">$<%=
                                            Number(locals.total).toFixed(2) %></span>
                                </div>

                                <% if (!locals.userLogged) { %>
                                    <div
                                        style="background: rgba(37, 99, 235, 0.1); border: 1px solid var(--secondary-color); border-radius: 8px; padding: 15px; text-align: center; margin-bottom: 20px;">
                                        <p style="color: var(--text-main); font-size: 13px; line-height: 1.5;">✨ <a
                                                href="/login"
                                                style="color: var(--primary-color); font-weight: bold; text-decoration: underline;">Inicia
                                                sesión</a> para guardar tu carrito y acumular puntos de descuento.</p>
                                    </div>
                                    <% } %>

                                        <a href="/checkout" class="btn-primary"
                                            style="display: block; width: 100%; text-align: center; border-radius: 8px; padding: 15px; font-size: 16px; font-weight: 600; letter-spacing: 0.5px; box-sizing: border-box;">
                                            Finalizar Compra <i class="fa-solid fa-arrow-right"
                                                style="margin-left: 8px;"></i>
                                        </a>

                                        <div style="text-align: center; margin-top: 20px;">
                                            <a href="/"
                                                style="color: var(--text-light); font-size: 14px; text-decoration: none; transition: color 0.3s;"
                                                onmouseover="this.style.color='var(--primary-color)';"
                                                onmouseout="this.style.color='var(--text-light)';">
                                                <i class="fa-solid fa-arrow-left-long" style="margin-right: 5px;"></i>
                                                Seguir comprando
                                            </a>
                                        </div>
                            </div>
                        </div>

                        <% } else { %>
                            <!-- Empty State (Carrito Vacío) -->
                            <div
                                style="text-align: center; padding: 80px 20px; background: var(--surface-main); border-radius: 12px; border: 1px dashed var(--border-color); max-width: 600px; margin: 0 auto;">
                                <div
                                    style="display: inline-flex; align-items: center; justify-content: center; width: 100px; height: 100px; border-radius: 50%; background-color: var(--bg-body); margin-bottom: 25px;">
                                    <i class="fa-solid fa-cart-arrow-down"
                                        style="font-size: 40px; color: var(--text-light);"></i>
                                </div>
                                <h2 style="color: var(--text-main); font-size: 28px; margin-bottom: 15px;">Tu carrito
                                    está vacío 😔</h2>
                                <p style="color: var(--text-light); font-size: 16px; margin-bottom: 30px;">¡No te
                                    preocupes! Tenemos cientos de repuestos y herramientas esperándote.</p>
                                <a href="/" class="btn-primary"
                                    style="border-radius: 8px; padding: 15px 30px; font-size: 16px; font-weight: 600;">
                                    <i class="fa-solid fa-store" style="margin-right: 8px;"></i> Explorar Catálogo
                                </a>
                            </div>
                            <% } %>
                </div>
            </main>

            <%- include('../partials/footer') %>
    </body>

</html>