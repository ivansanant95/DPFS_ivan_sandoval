<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Reparatech - Finalizar Compra' , cssFile: 'forms.css' }) %>
    <style>
        .checkout-container {
            max-width: 800px;
            margin: 40px auto;
            padding: 20px;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .checkout-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        .checkout-table th,
        .checkout-table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #eee;
        }

        .checkout-total {
            text-align: right;
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--primary-color);
        }

        .btn-confirm {
            display: block;
            width: 100%;
            padding: 15px;
            background: #27ae60;
            color: #fff;
            border: none;
            border-radius: 5px;
            font-size: 1.2rem;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            margin-top: 20px;
        }
    </style>

    <body>
        <%- include('../partials/header') %>
            <main>
                <section class="checkout-container">
                    <h1 style="text-align: center; color: var(--primary-color);">Resumen de tu Pedido</h1>
                    <table class="checkout-table">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Cant.</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cartProducts.forEach(item=> { %>
                                <tr>
                                    <td>
                                        <%= item.product.name %>
                                    </td>
                                    <td>
                                        <%= item.quantity %>
                                    </td>
                                    <td>$<%= (item.unit_price * item.quantity).toFixed(2) %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                    <div class="checkout-total">Total: $<%= total.toFixed(2) %>
                    </div>

                    <form action="/checkout/confirm" method="POST">
                        <button type="submit" class="btn-confirm">Confirmar y Realizar Pedido 🚀</button>
                    </form>
                    <p style="text-align: center; margin-top: 15px;"><a href="/cart" style="color: #777;">Volver al
                            carrito</a></p>
                </section>
            </main>
            <%- include('../partials/footer') %>
    </body>

</html>