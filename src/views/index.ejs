<!DOCTYPE html>
<html lang="es">
<!-- Head (título y CSS específicos) -->
<%- include('./partials/head', { title: 'Reparatech - Especialistas en Telefonía Móvil' , cssFile: 'home.css' }) %>

    <body>

        <!-- Header -->
        <%- include('./partials/header') %>

            <!-- CONTENIDO PRINCIPAL (MAIN) -->
            <main>
                <!-- Banner Principal -->
                <section class="home-banner">
                    <div class="banner-content">
                        <h1>Tu celular merece una segunda oportunidad</h1>
                        <p>Encuentra los mejores repuestos, herramientas y servicio técnico especializado.</p>
                        <a href="#" class="btn-primary">Explorar Servicios</a>
                    </div>
                </section>

                <!-- Sección de Productos Destacados -->
                <section class="featured-products">
                    <h2 class="section-title">Productos Destacados</h2>

                    <div class="product-grid">
                        <% if (products && products.length> 0) { %>
                            <% products.forEach(product=> { %>
                                <article class="product-card">
                                    <div class="product-image">
                                        <img src="<%= product.image %>" alt="<%= product.name %>">
                                    </div>
                                    <div class="product-info">
                                        <h3>
                                            <%= product.name %>
                                        </h3>
                                        <!-- Formateamos el precio para que siempre tenga 2 decimales -->
                                        <p class="price">$<%= Number(product.price).toFixed(2) %>
                                        </p>
                                        <a href="/products/<%= product.id %>" class="btn-secondary">Ver Detalles</a>
                                    </div>
                                </article>
                                <% }) %>
                                    <% } else { %>
                                        <p style="text-align: center; width: 100%; color: var(--text-light);">No hay
                                            productos disponibles por el momento.</p>
                                        <% } %>
                    </div>
                </section>
            </main>

            <!-- Footer -->
            <%- include('./partials/footer') %>

    </body>

</html>