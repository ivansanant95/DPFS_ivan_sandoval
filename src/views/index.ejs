<!DOCTYPE html>
<html lang="es">
<!-- Head (título y CSS específicos) -->
<%- include('./partials/head', { title: 'Reparatech - Especialistas en Telefonía Móvil' , cssFile: 'home.css' }) %>

    <body>

        <!-- Header -->
        <%- include('./partials/header') %>

            <!-- CONTENIDO PRINCIPAL (MAIN) -->
            <main>
                <!-- Banner Principal -->
                <section class="home-banner">
                    <div class="banner-content">
                        <h1>Tu celular merece una segunda oportunidad</h1>
                        <p>Encuentra los mejores repuestos, herramientas y servicio técnico especializado.</p>
                        <a href="#" class="btn-primary">Explorar Servicios</a>
                    </div>
                </section>

                <!-- Sección de Productos Destacados -->
                <section class="featured-products">
                    <h2 class="section-title">Productos Destacados</h2>

                    <div class="product-grid">
                        <!-- Producto 1 -->
                        <article class="product-card">
                            <div class="product-image">
                                <img src="https://via.placeholder.com/200x200?text=iPhone+X+Pantalla"
                                    alt="Pantalla iPhone X">
                            </div>
                            <div class="product-info">
                                <h3>Módulo Pantalla iPhone X Original</h3>
                                <p class="price">$120.00</p>
                                <a href="/detail" class="btn-secondary">Ver Detalles</a>
                            </div>
                        </article>

                        <!-- Producto 2 -->
                        <article class="product-card">
                            <div class="product-image">
                                <img src="https://via.placeholder.com/200x200?text=Kit+Herramientas"
                                    alt="Kit de Herramientas iFixit">
                            </div>
                            <div class="product-info">
                                <h3>Kit de Herramientas Premium 54 piezas</h3>
                                <p class="price">$45.00</p>
                                <a href="/detail" class="btn-secondary">Ver Detalles</a>
                            </div>
                        </article>

                        <!-- Producto 3 -->
                        <article class="product-card">
                            <div class="product-image">
                                <img src="https://via.placeholder.com/200x200?text=Bateria+Samsung+S21"
                                    alt="Batería Samsung S21">
                            </div>
                            <div class="product-info">
                                <h3>Batería Original Samsung S21</h3>
                                <p class="price">$35.00</p>
                                <a href="/detail" class="btn-secondary">Ver Detalles</a>
                            </div>
                        </article>

                        <!-- Producto 4 -->
                        <article class="product-card">
                            <div class="product-image">
                                <img src="https://via.placeholder.com/200x200?text=Estacion+Soldado"
                                    alt="Estación de Soldado">
                            </div>
                            <div class="product-info">
                                <h3>Estación de Soldado Profesional</h3>
                                <p class="price">$85.00</p>
                                <a href="/detail" class="btn-secondary">Ver Detalles</a>
                            </div>
                        </article>
                    </div>
                </section>
            </main>

            <!-- Footer -->
            <%- include('./partials/footer') %>

    </body>

</html>