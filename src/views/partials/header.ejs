<!-- =========================
     ENCABEZADO GLOBAL (HEADER)
     ========================= -->
<header class="main-header">
    <div class="header-top">
        <a href="/" class="logo">Repara<span>Tech</span></a>
        <% if (!locals.userLogged || locals.userLogged.role_id !==1) { %>
            <div class="search-bar">
                <input type="text" placeholder="Buscar celulares, repuestos, herramientas...">
                <button type="button">Buscar</button>
            </div>
            <% } %>
                <div class="user-actions">
                    <!-- Si el usuario NO está logueado -->
                    <% if (!locals.isLogged) { %>
                        <a href="/login" class="btn-login">Ingresar</a>
                        <% } else { %>
                            <!-- Si el usuario SÍ está logueado -->
                            <a href="/profile" class="btn-login"
                                style="background-color: transparent; color: var(--primary-color); display: flex; align-items: center; gap: 8px;">
                                <% let avatarUrl=(locals.userLogged.image && locals.userLogged.image
                                    !=='default-avatar.png' ) ? '/images/users/' + locals.userLogged.image :
                                    `https://ui-avatars.com/api/?name=${locals.userLogged.firstName}+${locals.userLogged.lastName}&background=27ae60&color=fff&rounded=true`;
                                    %>
                                    <img src="<%= avatarUrl %>" alt="Avatar"
                                        style="width: 30px; height: 30px; border-radius: 50%; object-fit: cover;">
                                    Hola, <%= locals.userLogged.firstName %>
                            </a>
                            <% } %>
                                <% if (!locals.userLogged || locals.userLogged.role_id !==1) { %>
                                    <a href="/cart" class="btn-cart">🛍️ Mi Carrito</a>
                                    <% } %>
                </div>
    </div>

    <nav class="main-nav">
        <ul class="nav-links">
            <% if (!locals.userLogged || locals.userLogged.role_id !==1) { %>
                <li><a href="#">Celulares</a></li>
                <li><a href="#">Servicio Técnico</a></li>
                <li><a href="#">Repuestos</a></li>
                <li><a href="#">Herramientas</a></li>
                <% } %>

                    <!-- Solo mostramos "Crear Cuenta" a los visitantes -->
                    <% if (!locals.isLogged) { %>
                        <li><a href="/register">Crear Cuenta</a></li>
                        <% } %>
                            <!-- Panel de Admin -->
                            <% if (locals.userLogged && locals.userLogged.role_id===1) { %>
                                <li><a href="/products/create" style="color: var(--primary-color); font-weight: bold;">+
                                        Nuevo
                                        Producto</a></li>
                                <li><a href="/admin/users" style="color: #666; font-weight: bold;">👥 Usuarios</a></li>
                                <% } %>
        </ul>
    </nav>
</header>