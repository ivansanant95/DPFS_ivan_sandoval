<!-- =========================
     ENCABEZADO GLOBAL (HEADER)
     ========================= -->
<header class="main-header">
    <div class="header-top">
        <a href="/" class="logo">Repara<span>Tech</span></a>
        <div class="search-bar">
            <input type="text" placeholder="Buscar celulares, repuestos, herramientas...">
            <button type="button">Buscar</button>
        </div>
        <div class="user-actions">
            <!-- vista de login para no mostrar el botón de "Ingresar" -->
            <% if (typeof hideLoginBtn==='undefined' || !hideLoginBtn) { %>
                <a href="/login" class="btn-login">Ingresar</a>
                <% } %>
                    <a href="/products/cart" class="btn-cart">🛍️ Carrito (0)</a>
        </div>
    </div>

    <nav class="main-nav">
        <ul class="nav-links">
            <li><a href="#">Celulares</a></li>
            <li><a href="#">Servicio Técnico</a></li>
            <li><a href="#">Repuestos</a></li>
            <li><a href="#">Herramientas</a></li>
            <!-- vista de registro -->
            <% if (typeof hideRegisterBtn==='undefined' || !hideRegisterBtn) { %>
                <li><a href="/register">Crear Cuenta</a></li>
                <% } %>
        </ul>
    </nav>
</header>