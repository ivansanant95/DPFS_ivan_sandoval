<!-- =========================
     ENCABEZADO GLOBAL (HEADER)
     ========================= -->
<header class="main-header">
    <div class="header-top">
        <a href="/" class="logo"><i class="fa-solid fa-mobile-screen-button"></i> Repara<span>Tech</span></a>
        <% if (!locals.userLogged || locals.userLogged.role_id !==1) { %>
            <div class="search-bar" style="display: none;">
                <i class="fa-solid fa-magnifying-glass"
                    style="color: var(--text-light); margin-left: 15px; align-self: center;"></i>
                <input type="text" placeholder="Buscar celulares, repuestos, herramientas..."
                    style="padding-left: 10px;">
                <button type="button">Buscar</button>
            </div>
            <% } %>
                <div class="user-actions">
                    <!-- Si el usuario NO está logueado -->
                    <% if (!locals.isLogged) { %>
                        <a href="/login" class="btn-login"><i class="fa-regular fa-user"></i> Ingresar</a>
                        <% } else { %>
                            <!-- Si el usuario SÍ está logueado -->
                            <a href="/profile" class="btn-login"
                                style="background-color: transparent; color: var(--primary-color); display: flex; align-items: center; gap: 8px; border: 1px solid var(--border-color);">
                                <% let avatarUrl=(locals.userLogged.image && locals.userLogged.image
                                    !=='default-avatar.png' ) ? '/images/users/' + locals.userLogged.image :
                                    `https://ui-avatars.com/api/?name=${locals.userLogged.firstName}+${locals.userLogged.lastName}&background=0f172a&color=fff&rounded=true`;
                                    %>
                                    <img src="<%= avatarUrl %>" alt="Avatar"
                                        style="width: 28px; height: 28px; border-radius: 50%; object-fit: cover;">
                                    <%= locals.userLogged.firstName %>
                            </a>
                            <% } %>
                                <% if (!locals.userLogged || locals.userLogged.role_id !==1) { %>
                                    <a href="/cart" class="btn-cart"><i class="fa-solid fa-cart-shopping"></i> Mi
                                        Carrito</a>
                                    <% } %>
                </div>
    </div>

    <nav class="main-nav">
        <ul class="nav-links">
            <% if (!locals.userLogged || locals.userLogged.role_id !==1) { %>
                <!-- Enlaces del catálogo visible solo para NO-ADMS -->
                <li><a href="/products/category/1"><i class="fa-solid fa-mobile-retro"></i> Celulares</a></li>
                <li><a href="/services"><i class="fa-solid fa-screwdriver-wrench"></i> Servicio Técnico</a></li>
                <li><a href="/products/category/2"><i class="fa-solid fa-microchip"></i> Repuestos</a></li>
                <li><a href="/products/category/3"><i class="fa-solid fa-toolbox"></i> Herramientas</a></li>
                <% } %>

                    <!-- Solo mostramos "Crear Cuenta" a los visitantes -->
                    <% if (!locals.isLogged) { %>
                        <li><a href="/register"><i class="fa-solid fa-user-plus"></i> Crear Cuenta</a></li>
                        <% } %>

                            <!-- Panel de Admin (Destacado) -->
                            <% if (locals.userLogged && locals.userLogged.role_id===1) { %>
                                <li><a href="/products/create"
                                        style="color: var(--secondary-color); font-weight: bold;"><i
                                            class="fa-solid fa-plus-circle"></i> Nuevo Producto</a></li>
                                <li><a href="/services" style="color: #10b981; font-weight: bold;"><i
                                            class="fa-solid fa-screwdriver-wrench"></i> Gestionar Servicios</a></li>
                                <li><a href="/admin/users" style="color: var(--surface-hover); font-weight: bold;"><i
                                            class="fa-solid fa-users"></i> Usuarios</a></li>
                                <% } %>
        </ul>
    </nav>
</header>