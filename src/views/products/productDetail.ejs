<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Reparatech - ' + product.name, cssFile: 'product.css' }) %>

    <body>

        <%- include('../partials/header') %>

            <!-- CONTENIDO PRINCIPAL -->
            <main>
                <!-- Migas de pan: Inicio > Categoría > > Producto -->
                <div class="breadcrumb">
                    <a href="/">Inicio</a>
                    <% if (product.category) { %>
                        > <a href="/products/category/<%= product.category.id %>">
                            <%= product.category.name %>
                        </a>
                        <% } %>
                            > > <%= product.name %>
                </div>

                <section class="product-detail-container">
                    <!-- Galería de Fotos (Izquierda) -->
                    <div class="product-gallery">
                        <div class="main-image">
                            <img src="<%= product.image %>" alt="<%= product.name %>">
                        </div>
                        <div class="thumbnails">
                            <img src="<%= product.image %>" class="thumbnail active" alt="Miniatura 1">
                        </div>
                    </div>

                    <!-- Información y Compra (Derecha) -->
                    <div class="product-info-detail">
                        <h1 class="product-title">
                            <%= product.name %>
                        </h1>
                        <p class="product-sku">SKU: REP-<%= product.id %> | Condición: Nuevo</p>

                        <!-- Lógica de Precios con Descuento para Registrados -->
                        <% if (locals.userLogged && product.discount> 0) { %>
                            <div class="pricing-socio-detail">
                                <p class="product-price-large"
                                    style="text-decoration: line-through; color: #999; font-size: 1.2em; margin-bottom: 0;">
                                    Original: $<%= Number(product.price).toFixed(2) %>
                                </p>
                                <p class="product-price-large"
                                    style="color: #27ae60; font-weight: bold; font-size: 2em; margin-top: 5px;">$<%=
                                        Number(product.price - (product.price * product.discount / 100)).toFixed(2) %>
                                        <span style="font-size: 0.5em;">(Precio Socio)</span></p>
                            </div>
                            <% } else { %>
                                <p class="product-price-large">$<%= Number(product.price).toFixed(2) %>
                                </p>
                                <% } %>

                                    <% if (product.colors && product.colors.length> 0) { %>
                                        <div class="variant-selector">
                                            <h4>Color:</h4>
                                            <div class="color-options">
                                                <% product.colors.forEach((color, index)=> { %>
                                                    <% let hex='#ccc' ; if(color==='negro' ) hex='#000' ;
                                                        if(color==='blanco' ) hex='#fff' ; if(color==='gris' )
                                                        hex='#e0e0e0' ; %>
                                                        <button class="color-btn <%= index === 0 ? 'active' : '' %>"
                                                            style="background-color: <%= hex %>;"
                                                            title="<%= color %>"></button>
                                                        <% }) %>
                                            </div>
                                        </div>
                                        <% } %>

                                            <!-- Agregar al carrito -->
                                            <form action="/cart/add/<%= product.id %>" method="POST" style="margin: 0;">
                                                <button type="submit" class="btn-add-to-cart">
                                                    Agregar al Carrito
                                                </button>
                                            </form>

                                            <% if (locals.userLogged && locals.userLogged.role_id===1) { %>
                                                <div style="margin-top: 15px; display: flex; gap: 10px;">
                                                    <a href="/products/<%= product.id %>/edit" class="btn-secondary"
                                                        style="text-align: center; flex: 1; padding: 12px; border-radius: 5px;">✏️
                                                        Editar Producto</a>
                                                </div>
                                                <% } %>

                                                    <!-- Toda la info relevante -->
                                                    <div class="product-description-tabs">
                                                        <h3>Descripción del Repuesto</h3>
                                                        <p>
                                                            <%= product.description %>
                                                        </p>
                                                    </div>
                    </div>
                </section>
            </main>

            <%- include('../partials/footer') %>

    </body>

</html>