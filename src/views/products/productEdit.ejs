<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Admin - Editar Producto' , cssFile: 'forms.css' }) %>

    <body>
        <%- include('../partials/header') %>

            <main>
                <section class="form-container" style="max-width: 700px;">
                    <h1 class="form-title">Editando: Módulo Pantalla iPhone X</h1>
                    <p style="text-align: center; color: var(--text-light); margin-bottom: 20px;">
                        Modifique los campos necesarios y aplique los cambios
                    </p>

                    <!-- El action apuntará a /products/:id (PUT)  -->
                    <form action="#" method="get" class="admin-form">

                        <!-- Nombre pre-llenado -->
                        <div class="form-group">
                            <label for="name">Nombre del Producto *</label>
                            <input type="text" id="name" name="name" value="Módulo Pantalla Original para iPhone X"
                                required>
                        </div>

                        <!-- Precio y Categoría -->
                        <div class="form-row" style="display: flex; gap: 15px;">
                            <div class="form-group" style="flex: 1;">
                                <label for="price">Precio (USD) *</label>
                                <input type="number" id="price" name="price" value="120.00" step="0.01" required>
                            </div>

                            <div class="form-group" style="flex: 1;">
                                <label for="category">Categoría *</label>
                                <select id="category" name="category" class="form-control" required
                                    style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px;">
                                    <option value="celulares">Celulares</option>
                                    <option value="herramientas">Herramientas</option>
                                    <option value="repuestos" selected>Repuestos</option>
                                    <option value="accesorios">Accesorios</option>
                                </select>
                            </div>
                        </div>

                        <!-- Imagen Actual -->
                        <div class="form-group">
                            <label>Imagen Actual (Dejar vacío para mantener)</label>
                            <div style="margin-bottom: 10px;">
                                <img src="https://via.placeholder.com/80x80?text=iPhone+X" alt="Imagen actual"
                                    style="border-radius: 4px; border: 1px solid #ddd;">
                            </div>
                            <input type="file" id="image" name="image" accept="image/png, image/jpeg, image/webp"
                                style="padding: 10px 0;">
                        </div>

                        <!-- Colores disponibles -->
                        <div class="form-group">
                            <label>Colores Disponibles</label>
                            <div class="checkbox-group" style="display: flex; gap: 15px; margin-top: 5px;">
                                <label style="font-weight: normal;"><input type="checkbox" name="colors" value="negro"
                                        checked> Negro</label>
                                <label style="font-weight: normal;"><input type="checkbox" name="colors" value="blanco">
                                    Blanco</label>
                                <label style="font-weight: normal;"><input type="checkbox" name="colors" value="gris"
                                        checked> Gris</label>
                            </div>
                        </div>

                        <!-- Descripción pre-llenada -->
                        <div class="form-group">
                            <label for="description">Descripción Detallada *</label>
                            <textarea id="description" name="description" rows="5" required
                                style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-family: inherit; resize: vertical;">Módulo de pantalla táctil LCD OLED original para Apple iPhone X. Incluye marco ensamblado para una instalación más sencilla y segura. Testeada en laboratorio para evitar píxeles muertos. Requiere herramientas profesionales para su colocación.</textarea>
                        </div>

                        <div class="form-actions" style="display: flex; gap: 15px; margin-top: 30px;">
                            <button type="button" class="btn-secondary"
                                style="flex: 1; padding: 12px; border-radius: 5px; cursor:pointer;"
                                onclick="window.history.back()">Cancelar</button>
                            <!-- Simulated destroy button -->
                            <button type="button"
                                style="padding: 12px; background-color: #e74c3c; color: white; border: none; border-radius: 5px; cursor:pointer;"
                                onclick="alert('Funcionalidad de borrado en desarrollo')">🗑️ Borrar</button>
                            <button type="submit" class="btn-submit"
                                style="flex: 2; margin-top: 0; background-color: #27ae60;">Guardar Cambios</button>
                        </div>

                    </form>
                </section>
            </main>

            <%- include('../partials/footer') %>

    </body>

</html>