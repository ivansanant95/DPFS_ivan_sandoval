<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Admin - Editar Producto' , cssFile: 'forms.css' }) %>

    <body>
        <%- include('../partials/header') %>

            <main>
                <section class="form-container" style="max-width: 700px;">
                    <h1 class="form-title">Editando: Módulo Pantalla iPhone X</h1>
                    <p style="text-align: center; color: var(--text-light); margin-bottom: 20px;">
                        Modifique los campos necesarios y aplique los cambios
                    </p>

                    <!-- El action apunta a /products/:id activando PUT vía method-override -->
                    <form action="/products/<%= product.id %>?_method=PUT" method="POST" enctype="multipart/form-data"
                        class="admin-form">

                        <!-- Nombre pre-llenado -->
                        <div class="form-group">
                            <label for="name">Nombre del Producto *</label>
                            <input type="text" id="name" name="name"
                                value="<%= locals.oldData && oldData.name ? oldData.name : product.name %>" required>
                            <% if (locals.errors && errors.name) { %>
                                <span class="error-msg"
                                    style="color: red; font-size: 0.85rem; margin-top: 5px; display: block;">
                                    <%= errors.name.msg %>
                                </span>
                                <% } %>
                        </div>

                        <!-- Precio y Categoría -->
                        <div class="form-row" style="display: flex; gap: 15px;">
                            <div class="form-group" style="flex: 1;">
                                <label for="price">Precio (USD) *</label>
                                <input type="number" id="price" name="price"
                                    value="<%= locals.oldData && oldData.price ? oldData.price : product.price %>"
                                    step="0.01" required>
                                <% if (locals.errors && errors.price) { %>
                                    <span class="error-msg"
                                        style="color: red; font-size: 0.85rem; margin-top: 5px; display: block;">
                                        <%= errors.price.msg %>
                                    </span>
                                    <% } %>
                            </div>

                            <div class="form-group" style="flex: 1;">
                                <label for="category">Categoría *</label>
                                <select id="category" name="category" class="form-control" required
                                    style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px;">
                                    <% categories.forEach(cat=> { %>
                                        <option value="<%= cat.id %>" <%=(locals.oldData && oldData.category==cat.id) ||
                                            (!locals.oldData && product.category_id===cat.id) ? 'selected' : '' %>>
                                            <%= cat.name %>
                                        </option>
                                        <% }) %>
                                </select>
                                <% if (locals.errors && errors.category) { %>
                                    <span class="error-msg"
                                        style="color: red; font-size: 0.85rem; margin-top: 5px; display: block;">
                                        <%= errors.category.msg %>
                                    </span>
                                    <% } %>
                            </div>
                        </div>

                        <!-- Imagen Actual -->
                        <div class="form-group">
                            <label>Imagen Actual (Dejar vacío para mantener)</label>
                            <div style="margin-bottom: 10px;">
                                <img src="<%= product.image %>" alt="Imagen actual"
                                    style="border-radius: 4px; border: 1px solid #ddd; max-width: 150px;">
                            </div>
                            <!-- (Campo desactivado visualmente) -->
                            <input type="file" id="image" name="image" accept="image/png, image/jpeg, image/webp"
                                style="padding: 10px 0;">
                            <% if (locals.errors && errors.image) { %>
                                <span class="error-msg"
                                    style="color: red; font-size: 0.85rem; margin-top: 5px; display: block;">
                                    <%= errors.image.msg %>
                                </span>
                                <% } %>
                        </div>

                        <!-- Campo Stock -->
                        <div class="form-group">
                            <label for="stock">Cantidad en Stock</label>
                            <input type="number" id="stock" name="stock" value="<%= product.stock %>" min="0"
                                style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px;">
                        </div>

                        <!-- Descripción pre-llenada -->
                        <div class="form-group">
                            <label for="description">Descripción Detallada *</label>
                            <textarea id="description" name="description" rows="5" required
                                style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-family: inherit; resize: vertical;"><%= locals.oldData && oldData.description ? oldData.description : product.description %></textarea>
                            <% if (locals.errors && errors.description) { %>
                                <span class="error-msg"
                                    style="color: red; font-size: 0.85rem; margin-top: 5px; display: block;">
                                    <%= errors.description.msg %>
                                </span>
                                <% } %>
                        </div>

                        <div class="form-actions" style="display: flex; gap: 15px; margin-top: 30px;">
                            <button type="button" class="btn-secondary"
                                style="flex: 1; padding: 12px; border-radius: 5px; cursor:pointer;"
                                onclick="window.history.back()">Cancelar</button>
                            <!-- Submit del Formulario Edición -->
                            <button type="submit" class="btn-submit"
                                style="flex: 2; margin-top: 0; background-color: #27ae60;">Guardar Cambios</button>
                        </div>
                    </form>

                    <!-- Formulario de Borrado Independiente -->
                    <form action="/products/<%= product.id %>?_method=DELETE" method="POST"
                        style="margin-top: 15px; display: flex;">
                        <button type="submit"
                            style="flex: 1; padding: 12px; background-color: #e74c3c; color: white; border: none; border-radius: 5px; cursor:pointer;"
                            onclick="return confirm('¿Estás seguro de que deseas eliminar este producto definitivamente?')">🗑️
                            Borrar Producto</button>
                    </form>
                </section>
            </main>

            <%- include('../partials/footer') %>

    </body>

</html>