<!DOCTYPE html>
<html lang="es">
<!-- Head (título y CSS específicos) -->
<%- include('../partials/head', { title: title , cssFile: 'home.css' }) %>

    <body>

        <!-- Header -->
        <%- include('../partials/header') %>

            <!-- CONTENIDO PRINCIPAL (MAIN) -->
            <main>
                <!-- Sección de Productos de la Categoría -->
                <section class="featured-products">
                    <div class="section-header"
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; padding-bottom: 10px; border-bottom: 2px solid var(--border-color);">
                        <h1 class="section-title" style="font-size: 28px; color: var(--primary-color);">Categoría: <%=
                                categoryName %>
                        </h1>
                        <% if (locals.userLogged && locals.userLogged.role_id===1) { %>
                            <a href="/products/create" class="btn-primary">+ Crear Producto</a>
                            <% } %>
                    </div>

                    <div class="product-grid">
                        <% if (products && products.length> 0) { %>
                            <% products.forEach(product=> { %>
                                <article class="product-card">
                                    <div class="product-image">
                                        <img src="<%= product.image %>" alt="<%= product.name %>"
                                            style="object-fit: cover; border-radius: 8px;">
                                    </div>
                                    <div class="product-info">
                                        <h3>
                                            <%= product.name %>
                                        </h3>

                                        <div class="price-box">
                                            <% if (locals.userLogged && product.discount> 0) { %>
                                                <span class="price-original">$<%= Number(product.price).toFixed(2) %>
                                                        </span>
                                                <span class="price-discounted">
                                                    $<%= Number(product.price - (product.price * product.discount /
                                                        100)).toFixed(2) %>
                                                        <small>(Socio)</small>
                                                </span>
                                                <% } else { %>
                                                    <span class="price">$<%= Number(product.price).toFixed(2) %>
                                                    </span>
                                                    <% } %>
                                        </div>

                                        <% if (!locals.userLogged || locals.userLogged.role_id !==1) { %>
                                            <div style="display: flex; gap: 10px; margin-top: auto;">
                                                <a href="/products/<%= product.id %>" class="btn-secondary"
                                                    style="flex: 1;">Detalles</a>
                                                <form action="/cart/add/<%= product.id %>" method="POST"
                                                    style="margin: 0;">
                                                    <input type="hidden" name="quantity" value="1">
                                                    <button type="submit" class="btn-primary"
                                                        style="padding: 12px 15px; border-radius: 12px;"><i
                                                            class="fa-solid fa-cart-shopping"></i></button>
                                                </form>
                                            </div>
                                            <% } else { %>
                                                <div style="display: flex; gap: 10px; margin-top: auto;">
                                                    <a href="/products/<%= product.id %>/edit" class="btn-secondary"
                                                        style="flex: 1;"><i class="fa-solid fa-pen-to-square"></i>
                                                        Editar</a>
                                                    <form action="/products/<%= product.id %>?_method=DELETE"
                                                        method="POST" style="margin: 0;">
                                                        <button type="submit" class="btn-secondary"
                                                            style="background: rgba(231, 76, 60, 0.1); color: #e74c3c; border-color: rgba(231, 76, 60, 0.2);"
                                                            onclick="return confirm('¿Eliminar producto?')"><i
                                                                class="fa-solid fa-trash-can"></i></button>
                                                    </form>
                                                </div>
                                                <% } %>
                                    </div>
                                </article>
                                <% }) %>
                                    <% } else { %>
                                        <div
                                            style="grid-column: 1/-1; text-align: center; padding: 40px; background: var(--surface-main); border-radius: var(--radius-md); box-shadow: var(--shadow-sm);">
                                            <i class="fa-solid fa-box-open"
                                                style="font-size: 48px; color: var(--text-light); margin-bottom: 15px;"></i>
                                            <h3 style="color: var(--text-main); margin-bottom: 5px;">No hay productos
                                                aquí</h3>
                                            <p style="color: var(--text-light);">Aún no se han agregado artículos a la
                                                categoría <%= categoryName %>.</p>
                                        </div>
                                        <% } %>
                    </div>
                </section>
            </main>

            <!-- Footer -->
            <%- include('../partials/footer') %>

    </body>

</html>