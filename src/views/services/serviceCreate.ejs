<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: title, cssFile: 'home.css' }) %>

    <body>
        <%- include('../partials/header') %>

            <main style="background-color: var(--bg-body); padding: 60px 20px; min-height: 80vh;">
                <div class="container" style="max-width: 800px; margin: 0 auto;">

                    <!-- Breadcrumb / Header del Formulario -->
                    <div style="margin-bottom: 40px; text-align: left;">
                        <a href="/services"
                            style="color: var(--primary-color); text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; margin-bottom: 20px;">
                            <i class="fa-solid fa-arrow-left"></i> Volver al Catálogo
                        </a>
                        <h1 style="font-size: 32px; color: var(--text-main); font-weight: 800; margin-bottom: 10px;">
                            Nuevo <span style="color: var(--primary-color);">Servicio</span> Técnico</h1>
                        <p style="color: var(--text-light); font-size: 16px;">Completa el formulario para dar de alta un
                            nuevo servicio en el laboratorio.</p>
                    </div>

                    <!-- Card del Formulario -->
                    <div
                        style="background: var(--surface-main); border-radius: 16px; padding: 40px; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05); border: 1px solid var(--border-light);">
                        <form action="/services" method="POST" enctype="multipart/form-data"
                            style="display: flex; flex-direction: column; gap: 25px;">

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px;">
                                <!-- Nombre del Servicio -->
                                <div style="display: flex; flex-direction: column; gap: 8px; grid-column: 1 / -1;">
                                    <label for="name"
                                        style="font-size: 14px; font-weight: 700; color: var(--text-main); display: flex; align-items: center; gap: 6px;">
                                        <i class="fa-solid fa-tag"
                                            style="color: var(--primary-color); font-size: 12px;"></i> Nombre del
                                        Servicio
                                    </label>
                                    <input type="text" id="name" name="name"
                                        placeholder="Ej: Cambio de Pantalla iPhone 13" required
                                        value="<%= locals.oldData ? oldData.name : '' %>"
                                        style="padding: 14px 16px; border-radius: 10px; border: 1px solid <%= locals.errors && errors.name ? '#ef4444' : 'var(--border-light)' %>; background: var(--bg-body); color: var(--text-main); font-size: 15px; outline: none; transition: border-color 0.2s;">
                                    <% if (locals.errors && errors.name) { %>
                                        <span style="color: #ef4444; font-size: 12px; font-weight: 600;">
                                            <%= errors.name.msg %>
                                        </span>
                                        <% } %>
                                </div>

                                <!-- Precio -->
                                <div style="display: flex; flex-direction: column; gap: 8px;">
                                    <label for="price"
                                        style="font-size: 14px; font-weight: 700; color: var(--text-main); display: flex; align-items: center; gap: 6px;">
                                        <i class="fa-solid fa-circle-dollar-to-slot"
                                            style="color: var(--primary-color); font-size: 12px;"></i> Precio Base ($)
                                    </label>
                                    <input type="number" id="price" name="price" step="0.01" placeholder="0.00" required
                                        value="<%= locals.oldData ? oldData.price : '' %>"
                                        style="padding: 14px 16px; border-radius: 10px; border: 1px solid <%= locals.errors && errors.price ? '#ef4444' : 'var(--border-light)' %>; background: var(--bg-body); color: var(--text-main); font-size: 15px; outline: none;">
                                    <% if (locals.errors && errors.price) { %>
                                        <span style="color: #ef4444; font-size: 12px; font-weight: 600;">
                                            <%= errors.price.msg %>
                                        </span>
                                        <% } %>
                                </div>

                                <!-- Tiempo Estimado -->
                                <div style="display: flex; flex-direction: column; gap: 8px;">
                                    <label for="estimated_time"
                                        style="font-size: 14px; font-weight: 700; color: var(--text-main); display: flex; align-items: center; gap: 6px;">
                                        <i class="fa-solid fa-clock"
                                            style="color: var(--primary-color); font-size: 12px;"></i> Tiempo Estimado
                                    </label>
                                    <input type="text" id="estimated_time" name="estimated_time"
                                        placeholder="Ej: 2 a 4 horas" required
                                        value="<%= locals.oldData ? oldData.estimated_time : '' %>"
                                        style="padding: 14px 16px; border-radius: 10px; border: 1px solid <%= locals.errors && errors.estimated_time ? '#ef4444' : 'var(--border-light)' %>; background: var(--bg-body); color: var(--text-main); font-size: 15px; outline: none;">
                                    <% if (locals.errors && errors.estimated_time) { %>
                                        <span style="color: #ef4444; font-size: 12px; font-weight: 600;">
                                            <%= errors.estimated_time.msg %>
                                        </span>
                                        <% } %>
                                </div>
                            </div>

                            <!-- Descripción -->
                            <div style="display: flex; flex-direction: column; gap: 8px;">
                                <label for="description"
                                    style="font-size: 14px; font-weight: 700; color: var(--text-main); display: flex; align-items: center; gap: 6px;">
                                    <i class="fa-solid fa-align-left"
                                        style="color: var(--primary-color); font-size: 12px;"></i> Descripción Detallada
                                </label>
                                <textarea id="description" name="description" rows="4"
                                    placeholder="Describe el servicio, qué incluye y materiales utilizados..." required
                                    style="padding: 14px 16px; border-radius: 10px; border: 1px solid <%= locals.errors && errors.description ? '#ef4444' : 'var(--border-light)' %>; background: var(--bg-body); color: var(--text-main); font-size: 15px; outline: none; resize: vertical;"><%= locals.oldData ? oldData.description : '' %></textarea>
                                <% if (locals.errors && errors.description) { %>
                                    <span style="color: #ef4444; font-size: 12px; font-weight: 600;">
                                        <%= errors.description.msg %>
                                    </span>
                                    <% } %>
                            </div>

                            <!-- Imagen -->
                            <div style="display: flex; flex-direction: column; gap: 8px;">
                                <label for="image"
                                    style="font-size: 14px; font-weight: 700; color: var(--text-main); display: flex; align-items: center; gap: 6px;">
                                    <i class="fa-solid fa-image"
                                        style="color: var(--primary-color); font-size: 12px;"></i> Imagen Ilustrativa
                                </label>
                                <div style="border: 2px dashed <%= locals.errors && errors.image ? '#ef4444' : 'var(--border-light)' %>; border-radius: 12px; padding: 20px; text-align: center; background: var(--bg-body); cursor: pointer; transition: all 0.2s; position: relative;"
                                    onmouseover="this.style.borderColor='var(--primary-color)'; this.style.backgroundColor='rgba(37, 99, 235, 0.02)'"
                                    onmouseout="this.style.borderColor='<%= locals.errors && errors.image ? '#ef4444' : 'var(--border-light)' %>'; this.style.backgroundColor='var(--bg-body)'"
                                    onclick="document.getElementById('image').click();">
                                    <i class="fa-solid fa-cloud-arrow-up"
                                        style="font-size: 32px; color: var(--text-light); margin-bottom: 10px;"></i>
                                    <p style="font-size: 14px; color: var(--text-light); margin: 0;">Haz clic para subir
                                        una imagen o arrástrala aquí</p>
                                    <input type="file" id="image" name="image" accept="image/*" style="display: none;">
                                </div>
                                <% if (locals.errors && errors.image) { %>
                                    <span style="color: #ef4444; font-size: 12px; font-weight: 600;">
                                        <%= errors.image.msg %>
                                    </span>
                                    <% } %>
                            </div>

                            <!-- Descuento -->
                            <div style="display: flex; flex-direction: column; gap: 8px; width: 50%;">
                                <label for="discount"
                                    style="font-size: 14px; font-weight: 700; color: var(--text-main); display: flex; align-items: center; gap: 6px;">
                                    <i class="fa-solid fa-percent"
                                        style="color: var(--primary-color); font-size: 12px;"></i> Descuento (%)
                                </label>
                                <input type="number" id="discount" name="discount" min="0" max="100"
                                    value="<%= locals.oldData ? oldData.discount : '0' %>"
                                    style="padding: 14px 16px; border-radius: 10px; border: 1px solid var(--border-light); background: var(--bg-body); color: var(--text-main); font-size: 15px; outline: none;">
                            </div>

                            <!-- Botones de Acción -->
                            <div
                                style="display: flex; gap: 15px; margin-top: 15px; padding-top: 30px; border-top: 1px solid var(--border-light);">
                                <button type="submit" class="btn-primary"
                                    style="flex: 2; padding: 16px; border-radius: 12px; font-weight: 700; font-size: 16px; border: none; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 10px; transition: transform 0.2s;">
                                    <i class="fa-solid fa-plus"></i> Crear Servicio
                                </button>
                                <button type="reset"
                                    style="flex: 1; padding: 16px; border-radius: 12px; font-weight: 600; font-size: 15px; background: transparent; border: 1px solid var(--border-light); color: var(--text-light); cursor: pointer; transition: all 0.2s;"
                                    onmouseover="this.style.backgroundColor='var(--border-light)'; this.style.color='var(--text-main)'"
                                    onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--text-light)'">
                                    Limpiar
                                </button>
                            </div>

                        </form>
                    </div>
                </div>
            </main>

            <%- include('../partials/footer') %>
    </body>

</html>