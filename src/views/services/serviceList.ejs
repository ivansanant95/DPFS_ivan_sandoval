<!DOCTYPE html>
<html lang="es">
<!-- Reutiliza el Head global -->
<%- include('../partials/head', { title: title , cssFile: 'home.css' }) %>

    <body>

        <!-- Header -->
        <%- include('../partials/header') %>

            <main>
                <!-- Sección Catálogo de Servicios -->
                <section class="featured-products">

                    <!-- Hero / Header de la Sección de Servicios -->
                    <div class="section-header"
                        style="text-align: center; margin-bottom: 50px; padding-bottom: 30px; border-bottom: 1px solid var(--border-color);">
                        <div
                            style="display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 64px; border-radius: 50%; background-color: rgba(37, 99, 235, 0.1); margin-bottom: 15px;">
                            <i class="fa-solid fa-user-gear" style="font-size: 28px; color: var(--primary-color);"></i>
                        </div>
                        <h1 class="section-title" style="font-size: 36px; color: var(--text-main); font-weight: 700;">
                            Laboratorio de <span style="color: var(--primary-color);">Reparaciones</span></h1>
                        <p
                            style="color: var(--text-light); max-width: 600px; margin: 15px auto 0; font-size: 16px; line-height: 1.6;">
                            Confiabilidad, rapidez y garantía escrita. Selecciona el servicio que necesitas para
                            visualizar las características o reservar tu turno con nuestros técnicos expertos.
                        </p>
                    </div>

                    <!-- Grilla de Servicios -->
                    <div class="product-grid"
                        style="grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 30px;">
                        <% if (services && services.length> 0) { %>
                            <% services.forEach(service=> { %>
                                <article class="product-card"
                                    style="display: flex; flex-direction: column; border: 1px solid var(--border-light); transition: all 0.3s ease;">

                                    <!-- Thumbnail Placeholder del Servicio -->
                                    <div class="product-image"
                                        style="background: linear-gradient(145deg, var(--surface-main), var(--bg-body)); padding: 40px; display: flex; justify-content: center; align-items: center; border-bottom: 1px solid var(--border-light); position: relative; overflow: hidden;">
                                        <div
                                            style="position: absolute; width: 150px; height: 150px; background: radial-gradient(circle, var(--primary-color) 0%, transparent 70%); opacity: 0.1; border-radius: 50%; top: -20px; right: -20px;">
                                        </div>
                                        <i class="fa-solid fa-microchip"
                                            style="font-size: 56px; color: var(--primary-color); opacity: 0.8; z-index: 1;"></i>
                                    </div>

                                    <!-- Información del Servicio -->
                                    <div class="product-info"
                                        style="flex: 1; display: flex; flex-direction: column; padding: 25px;">
                                        <h3
                                            style="font-size: 20px; font-weight: 600; color: var(--text-main); margin-bottom: 12px; line-height: 1.3;">
                                            <%= service.name %>
                                        </h3>
                                        <p
                                            style="color: var(--text-light); font-size: 14px; flex: 1; line-height: 1.6;">
                                            <%= service.description %>
                                        </p>

                                        <!-- Footer Info (Precio y Tiempo) -->
                                        <div
                                            style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--border-light);">

                                            <!-- Bloque Precio -->
                                            <div style="display: flex; flex-direction: column;">
                                                <span
                                                    style="font-size: 11px; color: var(--text-light); text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px;">Costo
                                                    Base</span>
                                                <div style="display: flex; align-items: baseline; gap: 4px;">
                                                    <span
                                                        style="font-size: 26px; font-weight: 800; color: var(--text-main);">$
                                                        <%= Number(service.price).toFixed(2) %>
                                                    </span>
                                                </div>
                                            </div>

                                            <!-- Bloque Tiempo -->
                                            <div
                                                style="display: flex; flex-direction: column; align-items: flex-end; background-color: var(--surface-main); padding: 8px 12px; border-radius: 6px; border: 1px solid var(--border-light);">
                                                <span
                                                    style="font-size: 11px; color: var(--text-light); font-weight: 600; margin-bottom: 2px;"><i
                                                        class="fa-regular fa-clock" style="margin-right: 4px;"></i>
                                                    Demora Est.</span>
                                                <span
                                                    style="font-size: 13px; font-weight: 700; color: var(--primary-color);">
                                                    <%= service.estimated_time %>
                                                </span>
                                            </div>

                                        </div>

                                        <!-- Botón de Call To Action (Agendar/Detalles) -->
                                        <a href="/services/<%= service.id %>" class="btn-primary"
                                            style="margin-top: 20px; width: 100%; text-align: center; border-radius: 8px; font-weight: 600; letter-spacing: 0.5px; display: flex; justify-content: center; align-items: center; gap: 8px;">
                                            <i class="fa-regular fa-calendar-check"></i> Agendar Turno
                                        </a>
                                    </div>
                                </article>
                                <% }) %>
                                    <% } else { %>

                                        <!-- Empty State: Nulo Servicios Cargados -->
                                        <div
                                            style="grid-column: 1/-1; text-align: center; padding: 80px 20px; background: var(--surface-main); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--border-light);">
                                            <div
                                                style="display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px; border-radius: 50%; background-color: rgba(148, 163, 184, 0.1); margin-bottom: 20px;">
                                                <i class="fa-solid fa-clipboard-list"
                                                    style="font-size: 32px; color: var(--text-light);"></i>
                                            </div>
                                            <h3
                                                style="color: var(--text-main); font-size: 24px; font-weight: 600; margin-bottom: 12px;">
                                                Servicios Próximamente</h3>
                                            <p
                                                style="color: var(--text-light); font-size: 16px; max-width: 400px; margin: 0 auto;">
                                                Nuestro catálogo de reparaciones estará disponible muy pronto. ¡Vuelve a
                                                visitarnos!</p>
                                        </div>

                                        <% } %>
                    </div>
                </section>
            </main>

            <!-- Footer -->
            <%- include('../partials/footer') %>

    </body>

</html>