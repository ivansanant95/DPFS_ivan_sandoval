<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Reparatech - Iniciar Sesión' , cssFile: 'forms.css' }) %>

    <body>

        <%- include('../partials/header', { hideLoginBtn: true }) %>

            <!-- CONTENIDO PRINCIPAL (MAIN) -->
            <main>
                <!-- Contenedor del Formulario (Centrado) -->
                <section class="form-container">
                    <h1 class="form-title">Iniciar Sesión</h1>

                    <form action="/login" method="POST">

                        <% if (typeof errors !=='undefined' && errors.login) { %>
                            <div class="error-message"
                                style="color: #e74c3c; width: 100%; text-align: center; margin-bottom: 15px; background-color: #fce4e4; padding: 10px; border-radius: 5px;">
                                <%= errors.login.msg %>
                            </div>
                            <% } %>

                                <div class="form-group">
                                    <label for="email">Correo Electrónico</label>
                                    <input type="email" id="email" name="email" placeholder="tu_correo@ejemplo.com"
                                        required>
                                </div>

                                <div class="form-group">
                                    <label for="password">Contraseña</label>
                                    <input type="password" id="password" name="password"
                                        placeholder="Tu contraseña secreta" required>
                                </div>

                                <!-- Requisito: Opción de recordar contraseña / Recuperar contraseña -->
                                <a href="#" class="form-link">¿Olvidaste tu contraseña?</a>

                                <label class="form-checkbox">
                                    <input type="checkbox" name="remember" id="remember">
                                    Recordarme en este dispositivo
                                </label>

                                <!-- El type submit enviaría los datos al backend -->
                                <button type="submit" class="btn-submit">Ingresar a mi cuenta</button>
                    </form>

                    <p class="form-footerText">¿Aún no eres parte de Reparatech? <a href="/register">Regístrate
                            ahora</a></p>
                </section>
            </main>

            <%- include('../partials/footer') %>

    </body>

</html>