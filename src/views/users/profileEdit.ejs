<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Reparatech - Editar Perfil' , cssFile: 'forms.css' }) %>

    <body>
        <%- include('../partials/header') %>
            <main class="form-container">
                <h1>Editar mis datos</h1>
                <form action="/profile/edit?_method=PUT" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="firstName">Nombre</label>
                        <input type="text" name="firstName" id="firstName" value="<%= user.firstName %>" required>
                    </div>
                    <div class="form-group">
                        <label for="lastName">Apellido</label>
                        <input type="text" name="lastName" id="lastName" value="<%= user.lastName %>" required>
                    </div>
                    <div class="form-group">
                        <label for="phone">Teléfono</label>
                        <input type="text" name="phone" id="phone" value="<%= user.phone %>">
                    </div>
                    <div class="form-group">
                        <label for="avatar">Cambiar Avatar (Opcional)</label>
                        <input type="file" name="avatar" id="avatar" accept="image/*">
                    </div>
                    <button type="submit" class="btn-primary">Guardar Cambios</button>
                    <p style="text-align: center; margin-top: 15px;"><a href="/profile"
                            style="color: #666;">Cancelar</a></p>
                </form>
            </main>
            <%- include('../partials/footer') %>
    </body>

</html>