<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Reparatech - Crear Cuenta Nueva' , cssFile: 'forms.css' }) %>

    <body>

        <%- include('../partials/header', { hideRegisterBtn: true }) %>

            <!-- CONTENIDO PRINCIPAL (MAIN) -->
            <main>
                <!-- Contenedor del Formulario (Centrado) -->
                <section class="form-container" style="max-width: 600px;">
                    <h1 class="form-title">Crear Cuenta en Reparatech</h1>

                    <form action="#" method="get">

                        <!-- Demostración de Error de Validación  -->
                        <div class="form-group">
                            <label for="nombre">Nombre y Apellido *</label>
                            <input type="text" id="nombre" name="nombre" placeholder="Ej: Juan Pérez"
                                class="input-error">
                            <span class="error-message">El nombre no puede incluir caracteres especiales o estar
                                vacío.</span>
                        </div>

                        <div class="form-group">
                            <label for="email">Correo Electrónico *</label>
                            <input type="email" id="email" name="email" placeholder="tu_correo@ejemplo.com" required>
                        </div>

                        <div class="form-group">
                            <label for="telefono">Teléfono / WhatsApp</label>
                            <input type="text" id="telefono" name="telefono" placeholder="Ej: +54 11 1234 5678">
                        </div>

                        <div class="form-group">
                            <label for="password">Contraseña *</label>
                            <input type="password" id="password" name="password"
                                placeholder="Mínimo 8 caracteres numéricos y letras" required>
                        </div>

                        <div class="form-group">
                            <label for="confirm_password">Confirmar Contraseña *</label>
                            <input type="password" id="confirm_password" name="confirm_password"
                                placeholder="Mínimo 8 caracteres numéricos y letras" required>
                        </div>

                        <label class="form-checkbox">
                            <input type="checkbox" name="terms" id="terms" required>
                            Acepto los términos y condiciones y políticas de privacidad.
                        </label>

                        <button type="submit" class="btn-submit">Registrarme Gratis</button>
                    </form>

                    <p class="form-footerText">¿Ya tienes cuenta? <a href="/login">Ingresa aquí</a></p>
                </section>
            </main>

            <%- include('../partials/footer') %>

    </body>

</html>