<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head', { title: 'Reparatech - Crear Cuenta Nueva' , cssFile: 'forms.css' }) %>

    <body>

        <%- include('../partials/header', { hideRegisterBtn: true }) %>

            <!-- CONTENIDO PRINCIPAL (MAIN) -->
            <main>
                <!-- Contenedor del Formulario (Centrado) -->
                <section class="form-container" style="max-width: 600px;">
                    <h1 class="form-title">Crear Cuenta en Reparatech</h1>

                    <form action="/register" method="POST" enctype="multipart/form-data">

                        <!-- Nombre -->
                        <div class="form-group">
                            <label for="firstName">Nombre *</label>
                            <input type="text" id="firstName" name="firstName" placeholder="Ej: Juan"
                                value="<%= locals.oldData && oldData.firstName ? oldData.firstName : '' %>" required>
                            <% if (locals.errors && errors.firstName) { %>
                                <span class="error-msg"
                                    style="color: red; font-size: 0.85rem; margin-top: 5px; display: block;">
                                    <%= errors.firstName.msg %>
                                </span>
                                <% } %>
                        </div>

                        <!-- Apellido -->
                        <div class="form-group">
                            <label for="lastName">Apellido *</label>
                            <input type="text" id="lastName" name="lastName" placeholder="Ej: Pérez"
                                value="<%= locals.oldData && oldData.lastName ? oldData.lastName : '' %>" required>
                            <% if (locals.errors && errors.lastName) { %>
                                <span class="error-msg"
                                    style="color: red; font-size: 0.85rem; margin-top: 5px; display: block;">
                                    <%= errors.lastName.msg %>
                                </span>
                                <% } %>
                        </div>

                        <div class="form-group">
                            <label for="email">Correo Electrónico *</label>
                            <input type="email" id="email" name="email" placeholder="tu_correo@ejemplo.com"
                                value="<%= locals.oldData && oldData.email ? oldData.email : '' %>" required>
                            <% if (locals.errors && errors.email) { %>
                                <span class="error-msg"
                                    style="color: red; font-size: 0.85rem; margin-top: 5px; display: block;">
                                    <%= errors.email.msg %>
                                </span>
                                <% } %>
                        </div>

                        <div class="form-group">
                            <label for="telefono">Teléfono / WhatsApp</label>
                            <input type="text" id="telefono" name="phone" placeholder="Ej: +54 11 1234 5678"
                                value="<%= locals.oldData && oldData.phone ? oldData.phone : '' %>">
                        </div>

                        <!-- Subida de Foto -->
                        <div class="form-group">
                            <label for="avatar">Foto de Perfil (Avatar)</label>
                            <input type="file" id="avatar" name="avatar" accept="image/png, image/jpeg, image/webp"
                                style="padding: 10px 0;">
                            <% if (locals.errors && errors.avatar) { %>
                                <span class="error-msg"
                                    style="color: red; font-size: 0.85rem; margin-top: 5px; display: block;">
                                    <%= errors.avatar.msg %>
                                </span>
                                <% } %>
                        </div>

                        <div class="form-group">
                            <label for="password">Contraseña *</label>
                            <input type="password" id="password" name="password" placeholder="Mínimo 8 caracteres"
                                required>
                            <% if (locals.errors && errors.password) { %>
                                <span class="error-msg"
                                    style="color: red; font-size: 0.85rem; margin-top: 5px; display: block;">
                                    <%= errors.password.msg %>
                                </span>
                                <% } %>
                        </div>

                        <div class="form-group">
                            <label for="confirm_password">Confirmar Contraseña *</label>
                            <input type="password" id="confirm_password" name="confirm_password"
                                placeholder="Mínimo 8 caracteres" required>
                            <% if (locals.errors && errors.confirm_password) { %>
                                <span class="error-msg"
                                    style="color: red; font-size: 0.85rem; margin-top: 5px; display: block;">
                                    <%= errors.confirm_password.msg %>
                                </span>
                                <% } %>
                        </div>

                        <label class="form-checkbox">
                            <input type="checkbox" name="terms" id="terms" required>
                            Acepto los términos y condiciones y políticas de privacidad.
                        </label>

                        <button type="submit" class="btn-submit">Registrarme Gratis</button>
                    </form>

                    <p class="form-footerText">¿Ya tienes cuenta? <a href="/login">Ingresa aquí</a></p>
                </section>
            </main>

            <%- include('../partials/footer') %>

                <!-- Motor de Validación Front-end Vanilla JS -->
                <script src="/js/registerValidation.js"></script>

    </body>

</html>